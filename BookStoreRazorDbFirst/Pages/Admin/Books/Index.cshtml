
@page
@model BookStoreRazorDbFirst.Pages.Admin.Books.IndexModel

<div class="container mt-5">

    <div class="admin-card">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="admin-title">Kitap Yönetimi</h2>
                <p class="text-muted mb-0">Kitap ekle, güncelle, sil ve arama yap.</p>
            </div>

            <div>
                <a href="/Admin/Books/Create" class="btn btn-success">+ Yeni Kitap</a>
                <a href="/Admin/Reports" class="btn btn-dark">Raporlar</a>
            </div>
        </div>

        <form method="get" class="mb-4">
            <div class="input-group">
                <input name="search"
                       value="@Model.Search"
                       class="form-control"
                       placeholder="Kitap, yazar veya kategori ara..." />
                <button class="btn btn-primary">Ara</button>
            </div>
        </form>

        <table class="table table-modern table-hover">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Kitap</th>
                    <th>Yazar</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>İşlem</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Books)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.BookName</td>
                        <td>@item.Author</td>
                        <td><span class="category-badge">@item.Category</span></td>
                        <td class="fw-bold text-success">@item.Price ₺</td>
                        <td>@item.Stock</td>
                        <td>
                            <a href="/Admin/Books/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>

                            <form method="post" asp-page-handler="Delete" style="display:inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>